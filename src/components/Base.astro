---
import BaseHead from "@components/BaseHead.astro";
import Style from "./Style.astro";
import ThemeStore from "./ThemeStore.astro";
---

<html lang="en">
  <head>
    <BaseHead title="thegates.dev" />
    <slot name="head" />
    <Style />
    <ThemeStore />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    background-color: var(--col-bg);
    color: var(--col-fg);
  }
  body {
    height: 100%;
    width: 80%;
    margin: 0 auto;
  }
</style>
