---
import Home from "@layouts/Home.astro";
import PostTime from "@parts/PostTime.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("article");
---

<Home>
  <h1 class="title">Articles</h1>
  {
    articles.map(({ id, data: { title, description, published, updated } }) => (
      <article>
        <a href={`/articles/${id}`} class="card big wide stack">
          <h1>{title}</h1>
          <PostTime {published} {updated} />
          <p>{description}</p>
        </a>
      </article>
    ))
  }
</Home>
