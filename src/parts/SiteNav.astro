---
import NavLink from "./NavLink.astro";

const currentPage = new URL(Astro.request.url).pathname;
---

<nav class="site-nav">
  <ol role="list">
    <NavLink {currentPage} href="/">Home</NavLink>
    <NavLink {currentPage} href="/about">About me</NavLink>
  </ol>
</nav>

<style is:global>
  .site-nav {
    flex: 1;
  }
  @media screen and (max-width: 800px) {
    .site-nav {
      flex: 0;

      a {
        text-align: center;
      }
    }
  }
</style>
