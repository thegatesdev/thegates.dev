---
import { Icon } from "astro-icon/components";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  icon?: string;
  wide: boolean;
}

const { icon, wide, ...attrs } = Astro.props;
---

<a class:list={["card row", { wide: wide }, { big: wide }]} target="_blank" {...attrs}>
  <b><slot /></b>
  {icon && <Icon name={icon} />}
</a>
