---
import Base from "@layouts/Base.astro";
import Header from "@parts/Header.astro";
import Separator from "@parts/Separator.astro";
import SiteNav from "@parts/SiteNav.astro";
import EmptyPage from "@parts/EmptyPage.astro";
---

<Base>
  <Header />
  <Separator />
  <div class="layout-home">
    <SiteNav />
    <Separator vertical />
    <main class="layout-home-content">
      <slot>
        <EmptyPage />
      </slot>
    </main>
  </div>
</Base>

<style is:global>
  .layout-home {
    height: 100%;
    margin-bottom: var(--space-section-1);

    display: flex;
    flex-direction: row;
  }
  .layout-home-content {
    flex: 3;
  }
  @media screen and (max-width: 800px) {
    .layout-home {
      flex-direction: column;
      margin-bottom: 0;
    }
  }
</style>
